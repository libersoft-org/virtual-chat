		"@types/three": "^0.183.1",
		"vite": "^7.3.1",
		"typescript": "^5.9.3",
		"@types/node": "^25.4.0",
		"svelte-check": "^4.4.5",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1"
	},
	"dependencies": {
		"three": "^0.183.2"
